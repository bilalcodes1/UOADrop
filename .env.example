# UOADrop environment variables
# Copy to .env.local (web) or .env (desktop) and fill in real values.
# Never commit real secrets. See docs/SETUP.md for provisioning.

# ─────────────────────────────────────────
# Supabase (Phase 2)
# ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server-only, never expose to browser

# ─────────────────────────────────────────
# Resend email (Phase 4)
# ─────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=UOADrop <no-reply@yourdomain.com>

# ─────────────────────────────────────────
# Telegram bot (Phase 4)
# ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=     # random string, verify header on webhook

# ─────────────────────────────────────────
# Desktop app (librarian laptop)
# ─────────────────────────────────────────
DESKTOP_PORT=3737
DESKTOP_LAN_IP=192.168.50.10
DESKTOP_DB_PATH=./data/uoadrop.db
LIBRARIAN_PIN_HASH=          # bcrypt hash of librarian unlock PIN

# ─────────────────────────────────────────
# Feature flags
# ─────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
