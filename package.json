{
  "name": "uoadrop",
  "version": "0.1.0",
  "private": true,
  "description": "UOADrop — نظام طباعة مكتبة جامعية offline-first",
  "author": "Bilal <asel64152@icloud.com>",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:root": "eslint .",
    "desktop:runtime-config:write": "pnpm --filter @uoadrop/desktop runtime-config:write",
    "desktop:pack": "pnpm --filter @uoadrop/desktop pack",
    "desktop:dist:mac": "pnpm --filter @uoadrop/desktop dist:mac",
    "desktop:dist:win": "pnpm --filter @uoadrop/desktop dist:win"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.8.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "better-sqlite3"
    ]
  }
}
