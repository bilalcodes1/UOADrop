{
  "name": "@uoadrop/db-schema",
  "version": "0.1.0",
  "private": true,
  "description": "Drizzle ORM schema + migrations for Supabase Postgres and local SQLite",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./pg": "./src/pg.ts",
    "./sqlite": "./src/sqlite.ts"
  },
  "scripts": {
    "lint": "echo 'TODO: eslint' ",
    "typecheck": "tsc --noEmit",
    "generate:pg": "echo 'TODO: drizzle-kit generate --dialect=postgresql' ",
    "generate:sqlite": "echo 'TODO: drizzle-kit generate --dialect=sqlite' ",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
